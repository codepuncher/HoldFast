{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "includes": [
    "README.md",
    "docs/**/*.md"
  ],
  "excludes": [
    "lib/**",
    "build/**",
    "vcpkg_installed/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.22.1.wasm"
  ],
  "markdown": {
    "textWrap": "maintain"
  }
}
